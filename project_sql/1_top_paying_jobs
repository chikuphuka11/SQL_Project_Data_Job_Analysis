/*
Question: What are the top paying Data Analyst and Business Analyst jobs?
- Identify the 100 highest paying jobs for Data Analysts and Business Analysts remotely.
- Focus on job postings with specified salaries (remove nulss).
- Why? Highlight the top-paying opportunities for Data Analysts and Business Analysts, offering insights into employment opprtunities fro these roles.
*/

SELECT
    job_id,
    job_title,
    job_location,
    job_schedule_type,
    salary_year_avg,
    job_posted_date,
    name AS company_name
FROM
    job_postings_fact
LEFT JOIN
    company_dim ON job_postings_fact.company_id = company_dim.company_id
WHERE
    (job_title_short = 'Data Analyst' OR job_title_short = 'Business Analyst') AND
    (job_location = 'Anywhere' OR job_location = 'Remote') AND
    salary_year_avg IS NOT NULL
ORDER BY
    salary_year_avg DESC
LIMIT 100